# =============================================================================
# Healthcare Agent — environment configuration
# =============================================================================
#
# Copy to `.env` and fill in [REQUIRED]/[SECRET] values. `docker compose up`
# reads this file automatically. Anything tagged [DEFAULT] can be safely
# omitted — the listed value will be used.
#
# Legend:
#   [REQUIRED]  Must be set or the process refuses to start.
#   [SECRET]    Treat as credential material; never commit a real value.
#   [DEFAULT]   Optional override; the shown value is what the app uses if blank.
#
# Every variable below is read somewhere in the code. If you add a new env var
# to the codebase, add it here too — the compose YAML expects this file to be
# the canonical surface.
# =============================================================================


# ---- Postgres ---------------------------------------------------------------
# Credentials for the bundled postgres container *and* the DATABASE_URL the
# backend uses to reach it. Change all three together.
POSTGRES_USER=app                              # [DEFAULT] app
POSTGRES_PASSWORD=change-me-in-prod            # [SECRET]  [DEFAULT] app
POSTGRES_DB=agentic_chat                       # [DEFAULT] agentic_chat


# ---- Core secrets -----------------------------------------------------------
# OPENAI_API_KEY: project key from https://platform.openai.com. The backend
# fails to start without it (see backend/src/env.ts).
OPENAI_API_KEY=sk-proj-REPLACE_ME              # [REQUIRED] [SECRET]

# JWT signing keypair (Ed25519 PEM). Used to sign session tokens. In dev the
# compose file substitutes literal "dev-*-key" placeholders; in prod you MUST
# provide real PEM-encoded keys (multi-line — wrap in quotes).
JWT_SIGNING_KEY_PRIVATE=dev-private-key        # [REQUIRED] [SECRET]
JWT_SIGNING_KEY_PUBLIC=dev-public-key          # [REQUIRED] [SECRET]

# HMAC key used by the log redactor to deterministically pseudonymize PII in
# audit logs. Rotate carefully — past redactions become un-correlatable.
REDACT_HMAC_KEY=healthcare-redact-dev-key      # [SECRET] [DEFAULT] healthcare-redact-dev-key


# ---- CORS / networking ------------------------------------------------------
# Comma-separated allow-list of browser origins for /api/. The compose stack
# exposes the frontend on :8080; the Vite dev server on :5173.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173  # [DEFAULT]


# ---- OpenAI tuning ----------------------------------------------------------
OPENAI_MODEL=gpt-5.2                           # [DEFAULT] primary chat model
OPENAI_REASONING_EFFORT=medium                 # [DEFAULT] none|low|medium|high|xhigh
OPENAI_BUDGET_MODEL=gpt-5.4-mini               # [DEFAULT] fallback when DAILY_BUDGET_USD nears cap
OPENAI_TTS_MODEL=gpt-4o-mini-tts               # [DEFAULT]
OPENAI_TTS_VOICE=alloy                         # [DEFAULT]


# ---- Agent loop caps --------------------------------------------------------
# Defense-in-depth limits. Lower these in prod once usage patterns settle.
MAX_AGENT_STEPS=5                              # [DEFAULT] tool-call iterations per turn
MAX_OUTPUT_TOKENS=2048                         # [DEFAULT] per LLM response
MAX_TURN_TOKENS=16000                          # [DEFAULT] total prompt+response per turn
MAX_TOOL_CALLS_PER_TURN=6                      # [DEFAULT]
LLM_TIMEOUT_MS=60000                           # [DEFAULT] hard timeout per LLM call


# ---- Cost controls ----------------------------------------------------------
# Soft budget; the agent switches to OPENAI_BUDGET_MODEL when the running
# daily spend exceeds this threshold, and rejects new turns past 2x.
DAILY_BUDGET_USD=5.00                          # [DEFAULT]


# ---- Retention windows (days) -----------------------------------------------
# Soft-delete after the conversations window; hard-delete after GRACE_DAYS.
# RETENTION_DAYS_AUDIT defaults to 7 years per HIPAA recordkeeping guidance.
RETENTION_DAYS_CONVERSATIONS=90                # [DEFAULT]
RETENTION_DAYS_USAGE=365                       # [DEFAULT]
RETENTION_DAYS_AUDIT=2555                      # [DEFAULT] ~7 years
RETENTION_DAYS_TTS_CACHE=30                    # [DEFAULT]
RETENTION_GRACE_DAYS=30                        # [DEFAULT] soft -> hard delete grace

# Retention worker scheduling (advanced).
RETENTION_CRON_INTERVAL_MS=86400000            # [DEFAULT] 24h
# AUDIT_ARCHIVE_BUCKET=s3://example-bucket     # optional: archive audit log before delete

# Audit chain verifier (advanced).
AUDIT_CHAIN_VERIFY_INTERVAL_MS=86400000        # [DEFAULT] 24h
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...# optional: page on chain break

# GDPR export job polling.
GDPR_EXPORT_POLL_MS=5000                       # [DEFAULT]


# ---- Observability ----------------------------------------------------------
# Langfuse (LLM tracing). Leave blank to disable — the langfuse module no-ops
# when keys are missing.
LANGFUSE_PUBLIC_KEY=                           # [SECRET]
LANGFUSE_SECRET_KEY=                           # [SECRET]
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # [DEFAULT]
LANGFUSE_SAMPLE_RATE=1.0                       # [DEFAULT] 0.0-1.0

# Prometheus /metrics exposure.
METRICS_ENABLED=false                          # [DEFAULT]

# Pino log level: trace|debug|info|warn|error|fatal.
LOG_LEVEL=info                                 # [DEFAULT]


# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production                            # [DEFAULT] production in compose; development locally
# PORT=3000                                    # [DEFAULT] only override for local non-docker runs


# ---- Redis ------------------------------------------------------------------
# REQUIRED by env.ts (the rate-limiter constructs an ioredis client at boot).
# Hostname `redis` resolves on the compose network; use `localhost` for
# bare-metal local runs.
REDIS_URL=redis://redis:6379                   # [REQUIRED]


# ---- Database --------------------------------------------------------------
# REQUIRED by env.ts. Compose composes this from POSTGRES_* automatically, but
# we keep it here so `bun run` outside docker works with no surprises. Use
# `localhost` instead of `postgres` when not in compose.
DATABASE_URL=postgres://app:change-me-in-prod@postgres:5432/agentic_chat  # [REQUIRED]


# ---- Feature flags ---------------------------------------------------------
ALLOW_REGISTRATION=true                        # [DEFAULT] gate POST /api/auth/register
MOCK_LLM=false                                 # [DEFAULT] true => deterministic scripted LLM (tests/CI)
MOCK_TTS=false                                 # [DEFAULT] true => deterministic mp3 fixture (tests/CI)


# ---- Metrics scrape gate ---------------------------------------------------
# METRICS_BEARER=                              # [SECRET] optional bearer for /metrics

# ---- Notes on advanced/optional vars ---------------------------------------
# Read via `process.env` directly (not validated by EnvSchema). Leave commented
# unless you wire up the integration:
#   AUDIT_ARCHIVE_BUCKET     — S3 sink for audit log before delete
#   ALERT_WEBHOOK_URL        — Slack/PagerDuty webhook for chain-break alerts
